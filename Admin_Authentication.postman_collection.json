									"raw": "{\n  \"email\": \"hemal@sarvadhi.com\",\n  \"password\": \"user_password\"\n}"
								},
								"url": {
									"raw": "{{base_url}}/api/auth/admin/login",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"api",
										"auth",
										"admin",
										"login"
									]
								},
								"description": "Regular user trying to access admin login should fail"
							},
							"response": []
