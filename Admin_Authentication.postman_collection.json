							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/forget-password",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
