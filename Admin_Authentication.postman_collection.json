{
	"info": {
		"_postman_id": "admin-auth-2025",
		"name": "Celora Admin Authentication & User Management",
		"description": "Admin login and user password management endpoints",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "1. Admin Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Has token and admin flag\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.true;",
									"    pm.expect(jsonData.data.token).to.exist;",
									"    pm.expect(jsonData.data.isAdmin).to.be.true;",
									"    ",
									"    // Save token for subsequent requests",
									"    pm.environment.set('admin_token', jsonData.data.token);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"pureyou@gmail.com\",\n  \"password\": \"your_admin_password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/admin/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"admin",
								"login"
							]
						},
						"description": "Admin login endpoint - Only accessible to users with admin roles (SUPERADMIN, ADMIN, GHB Admin)"
					},
					"response": []
				},
				{
					"name": "2. Regular User Login (for comparison)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Has token\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data.token).to.exist;",
									"    ",
									"    // Save token",
									"    pm.environment.set('user_token', jsonData.data.token);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"user_password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"login"
							]
						},
						"description": "Regular user login endpoint - accessible to all users"
					},
					"response": []
				},
				{
					"name": "3. Logout",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{admin_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/auth/logout",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"logout"
							]
						},
						"description": "Logout and blacklist the current token"
					},
					"response": []
				}
			]
		},
		{
			"name": "User Management",
			"item": [
				{
					"name": "1. Get All Users",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{admin_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/user",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"user"
							]
						},
						"description": "Get list of all users (admin only)"
					},
					"response": []
				},
				{
					"name": "2. Get User by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{admin_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/user/{{user_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"user",
								"{{user_id}}"
							]
						},
						"description": "Get specific user details"
					},
					"response": []
				},
				{
					"name": "3. Update User Password (Admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Password updated successfully\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.true;",
									"    pm.expect(jsonData.message).to.include('Password updated');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{admin_token}}",
								"description": "Admin token required"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"password\": \"newSecurePassword123\",\n  \"sendEmail\": false\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/admin/update-password/{{user_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"admin",
								"update-password",
								"{{user_id}}"
							]
						},
						"description": "Admin endpoint to update any user's password\n\nBody params:\n- password: New password (required, min 6 characters)\n- sendEmail: Boolean to send notification email (optional, default false)"
					},
					"response": []
				},
				{
					"name": "4. Update User Password with Email",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{admin_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"password\": \"newPassword456\",\n  \"sendEmail\": true\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/admin/update-password/{{user_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"admin",
								"update-password",
								"{{user_id}}"
							]
						},
						"description": "Update password and send notification email to user"
					},
					"response": []
				},
				{
					"name": "5. Update User Details",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{admin_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Updated Name\",\n  \"email\": \"newemail@example.com\",\n  \"role\": \"ADMIN\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/user/{{user_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"user",
								"{{user_id}}"
							]
						},
						"description": "Update user details (name, email, role, etc.)"
					},
					"response": []
				},
				{
					"name": "6. Delete User (Soft Delete)",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{admin_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/user/{{user_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"user",
								"{{user_id}}"
							]
						},
						"description": "Soft delete user (marks as inactive)"
					},
					"response": []
				}
			]
		},
		{
			"name": "Password Management",
			"item": [
