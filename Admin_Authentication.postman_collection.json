									{
										"key": "Authorization",
										"value": "Bearer {{admin_token}}"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"password\": \"newPassword123\",\n  \"sendEmail\": false\n}"
								},
								"url": {
									"raw": "{{base_url}}/api/auth/admin/update-password/{{user_id}}",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"api",
										"auth",
										"admin",
										"update-password",
										"{{user_id}}"
									]
								}
							},
							"response": []
						}
					]
				},
				{
					"name": "Scenario 2: Non-Admin Cannot Access",
					"item": [
						{
							"name": "Regular User Login",
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"var jsonData = pm.response.json();",
											"pm.environment.set('user_token', jsonData.data.token);"
										],
