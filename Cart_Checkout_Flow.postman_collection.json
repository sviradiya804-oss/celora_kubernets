{
	"info": {
		"_postman_id": "cart-checkout-flow-2025",
		"name": "Cart & Checkout Flow - Secure Payment with Quantity Tests",
		"description": "Complete cart and checkout flow with secure Stripe payment integration. Includes quantity update tests to verify:\n\n1. Adding same product twice increments quantity\n2. Manual quantity updates work correctly\n3. Secure payment with tokens (no raw card data)\n4. PCI compliant checkout\n\nNOTE: The GET cart endpoint may show 0 items due to a populate issue, but the cart functionality works correctly (add returns items, update works, checkout succeeds).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. User Login",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200) {",
							"    const jsonData = pm.response.json();",
							"    const data = jsonData.data || jsonData;",
							"    ",
							"    // Save token and userId for subsequent requests",
							"    pm.environment.set('authToken', data.token);",
							"    pm.environment.set('userId', data.user._id || data.user.id);",
							"    ",
							"    pm.test('Login successful', function() {",
							"        pm.expect(data.token).to.exist;",
							"    });",
							"    ",
							"    console.log('✅ Token saved:', data.token.substring(0, 30) + '...');",
							"    console.log('✅ User ID saved:', data.user._id || data.user.id);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"demo44@yopmail.com\",\n  \"password\": \"demo@123\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/auth/login",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"auth",
						"login"
					]
				},
				"description": "Authenticate user and get JWT token"
			},
			"response": []
		},
