		{
			"name": "5. Checkout with Token (Secure)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200) {",
							"    const jsonData = pm.response.json();",
							"    ",
							"    if (jsonData.success && jsonData.order) {",
							"        pm.environment.set('orderId', jsonData.order.orderId);",
							"        ",
							"        console.log('✅ Order placed successfully!');",
							"        console.log('📝 Order ID:', jsonData.order.orderId);",
							"        console.log('💳 Payment:', jsonData.order.paymentStatus);",
							"        console.log('💰 Total: $' + jsonData.order.total);",
							"        console.log('🔒 Card:', jsonData.order.cardBrand + ' *' + jsonData.order.cardLast4);",
							"    }",
							"    ",
							"    pm.test('Checkout successful', function() {",
							"        pm.expect(jsonData.success).to.be.true;",
							"        pm.expect(jsonData.order).to.exist;",
							"    });",
							"    ",
							"    pm.test('Payment completed', function() {",
							"        pm.expect(jsonData.order.paymentStatus).to.equal('completed');",
