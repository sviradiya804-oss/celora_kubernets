		{
			"name": "3. Add Product to Cart",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200) {",
							"    const jsonData = pm.response.json();",
							"    ",
							"    // Update sessionId if backend returns a new one",
							"    if (jsonData.sessionId) {",
							"        pm.environment.set('sessionId', jsonData.sessionId);",
							"        console.log('✅ Session ID updated:', jsonData.sessionId);",
							"    }",
							"    ",
							"    pm.test('Product added to cart', function() {",
							"        pm.expect(jsonData.success).to.be.true;",
							"    });",
							"}"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Generate unique session ID if not exists",
							"if (!pm.environment.get('sessionId')) {",
							"    pm.environment.set('sessionId', Date.now().toString());",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{authToken}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"userId\": \"{{userId}}\",\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 1,\n  \"selectedVariant\": {\n    \"selectedOptions\": {\n      \"ringsize\": \"6.5\",\n      \"metaldetail\": \"6747ebd7ae6e93d5e8a0e7a1\"\n    }\n  }\n}"
				},
