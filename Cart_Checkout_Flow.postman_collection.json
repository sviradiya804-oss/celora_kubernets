						"{{baseUrl}}"
					],
					"path": [
						"api",
						"cart",
						"add"
					]
				},
				"description": "Add a product with variants to the cart. You can use either 'productId' or '_id' parameter - both work! Product must be from Jewelry collection."
			},
			"response": []
