							"if (pm.response.code === 200) {",
							"    const jsonData = pm.response.json();",
							"    const products = jsonData.data || jsonData.jewelry || [];",
							"    ",
							"    if (products.length > 0) {",
							"        pm.environment.set('productId', products[0]._id);",
							"        console.log('✅ Product ID saved:', products[0]._id);",
							"        console.log('📦 Product:', products[0].title || products[0].name);",
							"    }",
							"    ",
							"    pm.test('Products retrieved', function() {",
							"        pm.expect(products.length).to.be.above(0);",
							"    });",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
