              "path": ["api", "cart", "checkout"]
            },
            "description": "Create Stripe checkout session from cart",
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "if (pm.response.to.have.status(200)) {",
                    "    const response = pm.response.json();",
                    "    if (response.sessionId) {",
                    "        pm.collectionVariables.set('STRIPE_SESSION_ID', response.sessionId);",
                    "    }",
                    "    if (response.orderId) {",
                    "        pm.collectionVariables.set('TEST_ORDER_ID', response.orderId);",
                    "    }",
                    "}"
                  ]
                }
              }
            ]
          },
          "response": []
        },
