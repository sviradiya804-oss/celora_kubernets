  "item": [
    {
      "name": "📁 A. CART INITIALIZATION",
      "item": [
        {
          "name": "1. Add First Product to Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 201', () => {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test('Product added successfully', () => {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data.success).to.eql(true);",
                  "  pm.expect(data.cart).to.exist;",
                  "  pm.expect(data.cart.items).to.be.an('array');",
                  "});",
                  "",
                  "// Save session ID for future requests",
                  "const requestBody = JSON.parse(pm.request.body.raw);",
                  "pm.collectionVariables.set('sessionId', requestBody.sessionId);",
                  "",
                  "// Save cart ID if returned",
                  "const data = pm.response.json();",
                  "if (data.cart && data.cart._id) {",
                  "  pm.collectionVariables.set('cartId', data.cart._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId1}}\",\n  \"quantity\": 1,\n  \"selectedOptions\": {\n    \"metaldetail\": \"{{metalId1}}\",\n    \"ringSize\": \"7\",\n    \"centerStone\": {\n      \"carat\": \"0.35\",\n      \"color\": \"D\",\n      \"clarity\": \"VVS1\",\n      \"shape\": \"Marquise\"\n    }\n  },\n  \"customizations\": {\n    \"metalType\": \"White Gold\",\n    \"gemstoneUpgrade\": true\n  },\n  \"engravingOptions\": {\n    \"engravingText\": \"Forever & Always\",\n    \"font\": \"Elegant Script\"\n  },\n  \"sessionId\": \"test-{{$timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cart/add",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "add"]
            },
            "description": "Add the first product to cart with customization options"
          }
        },
        {
          "name": "2. Add Second Product to Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 201', () => {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test('Second product added', () => {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data.success).to.eql(true);",
                  "  pm.expect(data.cart.items.length).to.be.greaterThan(1);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId2}}\",\n  \"quantity\": 2,\n  \"selectedOptions\": {\n    \"metaldetail\": \"{{metalId2}}\"\n  },\n  \"sessionId\": \"{{sessionId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cart/add",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "add"]
            },
            "description": "Add a second product to the existing cart"
          }
        },
        {
          "name": "3. Add Duplicate Product (Should Update Quantity)",
          "event": [
