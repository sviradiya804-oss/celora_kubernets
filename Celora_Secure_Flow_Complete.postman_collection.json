    {
      "name": "🔒 Security Validation Tests",
      "item": [
        {
          "name": "NoSQL Injection - Cart Add",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"test-session\",\n  \"userId\": {\"$ne\": null},\n  \"productId\": {\"$where\": \"this.price < 1000\"},\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/cart/add",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "cart", "add"]
            },
            "description": "🔴 Should FAIL - NoSQL injection attempt"
          },
          "response": []
        },
