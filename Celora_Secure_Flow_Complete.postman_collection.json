                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{TEST_SESSION_ID}}\",\n  \"userId\": \"{{TEST_USER_ID}}\",\n  \"code\": \"SAVE10\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/cart/apply-coupon",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "cart", "apply-coupon"]
            },
            "description": "Apply discount coupon (may fail if coupon doesn't exist)"
          },
          "response": []
        },
        {
          "name": "5. Proceed to Checkout (Enhanced)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{TEST_SESSION_ID}}\",\n  \"userId\": \"{{TEST_USER_ID}}\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/cart/checkout",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "cart", "checkout"]
            },
            "description": "Create enhanced Stripe checkout session with detailed product information, images, and customer data collection"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.to.have.status(200)) {",
                  "    const response = pm.response.json();",
                  "    if (response.sessionId) {",
                  "        pm.collectionVariables.set('STRIPE_SESSION_ID', response.sessionId);",
                  "        console.log('Stripe session ID saved:', response.sessionId);",
                  "    }",
                  "    if (response.orderId) {",
                  "        pm.collectionVariables.set('TEST_ORDER_ID', response.orderId);",
                  "        console.log('Order ID saved:', response.orderId);",
                  "    }",
                  "    if (response.orderSummary) {",
                  "        console.log('Order Summary:', JSON.stringify(response.orderSummary, null, 2));",
                  "    }",
                  "    ",
                  "    // Validate enhanced response",
                  "    pm.test('Response includes enhanced order data', function () {",
                  "        pm.expect(response).to.have.property('orderSummary');",
                  "        pm.expect(response.orderSummary).to.have.property('subtotal');",
                  "        pm.expect(response.orderSummary).to.have.property('total');",
                  "        pm.expect(response.orderSummary).to.have.property('itemCount');",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
