{
  "info": {
    "name": "🛒 Celora Backend - Secure Cart & Payment Flow",
    "description": "Complete API collection for cart management, checkout, payment processing, order management, and comprehensive security testing. Includes authentication flows, validation testing, and production-ready scenarios.",
    "version": "2.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "LOCAL_URL",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "Local development server"
    },
    {
      "key": "STAGING_URL",
      "value": "https://staging-api.celorajewelry.com",
      "type": "string",
      "description": "Staging environment"
    },
    {
      "key": "PROD_URL",
      "value": "https://api.celorajewelry.com",
      "type": "string",
      "description": "Production environment"
    },
    {
      "key": "BASE_URL",
      "value": "{{LOCAL_URL}}",
      "type": "string",
      "description": "Active environment - change this to switch environments"
    },
    {
      "key": "TEST_SESSION_ID",
      "value": "",
      "type": "string"
    },
    {
      "key": "TEST_USER_ID",
      "value": "66b123456789abcdef123456",
      "type": "string"
    },
    {
      "key": "VALID_PRODUCT_ID",
      "value": "",
      "type": "string",
      "description": "Will be populated from product search"
    },
    {
      "key": "TEST_ORDER_ID",
      "value": "",
      "type": "string"
    },
    {
      "key": "STRIPE_SESSION_ID",
      "value": "",
      "type": "string"
    },
    {
      "key": "AUTH_TOKEN",
      "value": "",
      "type": "string"
    },
    {
      "key": "ADMIN_TOKEN",
      "value": "",
      "type": "string"
    },
    {
      "key": "TEST_EMAIL",
      "value": "test@example.com",
      "type": "string"
    },
    {
      "key": "CUSTOMER_NAME",
      "value": "John Doe",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔧 Setup & Authentication",
      "item": [
        {
          "name": "Get Available Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/product?limit=5",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "product"],
              "query": [
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            },
            "description": "Get real products to use in testing"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Auto-populate product ID from response",
                  "if (pm.response.to.have.status(200)) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.length > 0) {",
                  "        const productId = response.data[0]._id;",
                  "        pm.collectionVariables.set('VALID_PRODUCT_ID', productId);",
                  "        console.log('Set VALID_PRODUCT_ID to:', productId);",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Generate Session ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/health",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "health"]
            },
            "description": "Health check and session generation"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Generate unique session ID",
                  "const sessionId = 'session-' + Date.now() + '-' + Math.random().toString(36).substr(2, 9);",
                  "pm.collectionVariables.set('TEST_SESSION_ID', sessionId);",
                  "console.log('Generated SESSION_ID:', sessionId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Test User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{CUSTOMER_NAME}}\",\n  \"email\": \"{{TEST_EMAIL}}\",\n  \"password\": \"TestPassword123!\",\n  \"confirmPassword\": \"TestPassword123!\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a test user (may fail if user exists)"
          },
          "response": []
        },
        {
          "name": "Login Test User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{TEST_EMAIL}}\",\n  \"password\": \"TestPassword123!\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login and get authentication token"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.to.have.status(200)) {",
                  "    const response = pm.response.json();",
                  "    if (response.token) {",
                  "        pm.collectionVariables.set('AUTH_TOKEN', response.token);",
                  "        console.log('Auth token saved');",
                  "    }",
                  "    if (response.user && response.user._id) {",
                  "        pm.collectionVariables.set('TEST_USER_ID', response.user._id);",
                  "        console.log('User ID updated to:', response.user._id);",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
