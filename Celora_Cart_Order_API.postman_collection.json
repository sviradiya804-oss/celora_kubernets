              "raw": "{{baseUrl}}/cart/view-cart?sessionId={{sessionId}}&userId={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "view-cart"],
              "query": [
                {
                  "key": "sessionId",
                  "value": "{{sessionId}}"
                },
                {
                  "key": "userId",
                  "value": "{{userId}}"
                }
              ]
            }
          },
          "response": []
