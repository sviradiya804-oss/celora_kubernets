              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"occasionId\": \"OCC-{{$randomInt}}\",\n  \"name\": \"Engagement\",\n  \"description\": \"Perfect for engagement ceremonies\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/occasion",
