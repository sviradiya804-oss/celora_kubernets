      ]
    },
    {
      "name": "Occasions & Ring Sizes",
      "item": [
        {
          "name": "Get All Occasions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/occasion",
              "host": ["{{baseUrl}}"],
              "path": ["api", "occasion"]
            }
          }
        },
        {
          "name": "Create Occasion",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
