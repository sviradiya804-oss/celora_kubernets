{
  "info": {
    "name": "Celora Backend - Jewelry Management",
    "description": "Complete collection for jewelry CRUD operations, categories, shapes, metals, diamonds, and all jewelry-related management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://celora-backend.vercel.app",
      "type": "string"
    },
    {
      "key": "localUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "jewelryId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Jewelry CRUD",
      "item": [
        {
          "name": "Create Jewelry with Images",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data._id) {",
                  "        pm.collectionVariables.set('jewelryId', response.data._id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "images",
                  "type": "file",
                  "src": "/path/to/jewelry-image-1.jpg"
                },
                {
                  "key": "images",
                  "type": "file",
                  "src": "/path/to/jewelry-image-2.jpg"
                },
                {
                  "key": "jewelryId",
                  "value": "JWL-{{$randomUUID}}",
                  "type": "text"
                },
                {
                  "key": "title",
                  "value": "Elegant Diamond Engagement Ring",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Beautiful solitaire engagement ring with VS1 clarity diamond",
                  "type": "text"
                },
                {
                  "key": "category",
                  "value": "6870abab68f9b4a37c8c856c",
                  "type": "text"
                },
                {
                  "key": "jewelryType",
                  "value": "Engagement Ring",
                  "type": "text"
                },
                {
                  "key": "type",
                  "value": "engagement",
                  "type": "text"
                },
                {
                  "key": "subTypeModel",
                  "value": "engagementsubtypelist",
                  "type": "text"
                },
                {
                  "key": "shape",
                  "value": "6884b4355b8a2ab54b74cd0a",
                  "type": "text"
                },
                {
                  "key": "metaldetail",
                  "value": "686ab482d853bd069777c9f2",
                  "type": "text"
                },
                {
                  "key": "occasion",
                  "value": "6870abab68f9b4a37c8c856c",
                  "type": "text"
                },
                {
                  "key": "status",
                  "value": "Active",
                  "type": "text"
                },
                {
                  "key": "featuredProduct",
                  "value": "true",
                  "type": "text"
                },
                {
                  "key": "inStock",
                  "value": "true",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/jewelry",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jewelry"]
            }
          }
        },
        {
          "name": "Create Jewelry (JSON)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jewelryId\": \"JWL-{{$randomUUID}}\",\n  \"title\": \"Classic Diamond Solitaire\",\n  \"description\": \"Timeless solitaire ring with premium diamond\",\n  \"slug\": \"classic-diamond-solitaire\",\n  \"category\": \"6870abab68f9b4a37c8c856c\",\n  \"jewelryType\": \"Engagement Ring\",\n  \"type\": \"engagement\",\n  \"subTypeModel\": \"engagementsubtypelist\",\n  \"cadCode\": \"CAD-{{$randomInt}}\",\n  \"shape\": \"6884b4355b8a2ab54b74cd0a\",\n  \"metaldetail\": \"686ab482d853bd069777c9f2\",\n  \"occasion\": \"6870abab68f9b4a37c8c856c\",\n  \"centerStone\": {\n    \"shape\": \"6884b4355b8a2ab54b74cd0a\",\n    \"carat\": 1.5,\n    \"color\": \"F\",\n    \"clarity\": \"VS1\",\n    \"cut\": \"Excellent\",\n    \"certification\": \"GIA\"\n  },\n  \"pricing\": {\n    \"basePrice\": 2500,\n    \"finalPrice\": 3600\n  },\n  \"engravingOptions\": {\n    \"available\": true,\n    \"maxCharacters\": 25,\n    \"additionalCost\": 50\n  },\n  \"status\": \"Active\",\n  \"featuredProduct\": true,\n  \"inStock\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/jewelry",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jewelry"]
            }
          }
        },
        {
          "name": "Get All Jewelry",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/jewelry?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jewelry"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "limit", "value": "10"}
              ]
            }
          }
        },
        {
          "name": "Get Single Jewelry",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/jewelry/{{jewelryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jewelry", "{{jewelryId}}"]
            }
          }
        },
        {
          "name": "Update Jewelry",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Elegant Diamond Ring\",\n  \"description\": \"Updated description with new features\",\n  \"pricing\": {\n    \"basePrice\": 2700,\n    \"finalPrice\": 3800\n  },\n  \"status\": \"Active\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/jewelry/{{jewelryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jewelry", "{{jewelryId}}"]
            }
          }
        },
        {
          "name": "Delete Jewelry",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/jewelry/{{jewelryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jewelry", "{{jewelryId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Categories & Collections",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/jewelrycategory",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jewelrycategory"]
            }
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
