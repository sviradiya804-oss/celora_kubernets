              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jewelryCategoryId\": \"CAT-{{$randomInt}}\",\n  \"name\": \"Engagement Rings\",\n  \"description\": \"Beautiful engagement rings for special moments\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/jewelrycategory",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jewelrycategory"]
            }
          }
        },
        {
          "name": "Get All Collections",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/collection",
              "host": ["{{baseUrl}}"],
              "path": ["api", "collection"]
            }
          }
        },
        {
          "name": "Create Collection",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"collectionId\": \"COL-{{$randomInt}}\",\n  \"name\": \"Classic Collection\",\n  \"description\": \"Timeless pieces that never go out of style\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/collection",
              "host": ["{{baseUrl}}"],
              "path": ["api", "collection"]
            }
          }
        }
      ]
    },
    {
      "name": "Shapes & Metals",
      "item": [
        {
          "name": "Get All Shapes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/shape",
              "host": ["{{baseUrl}}"],
              "path": ["api", "shape"]
            }
          }
        },
        {
          "name": "Create Shape",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shapeId\": \"SHP-{{$randomInt}}\",\n  \"name\": \"Round\",\n  \"description\": \"Classic round brilliant cut\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/shape",
              "host": ["{{baseUrl}}"],
              "path": ["api", "shape"]
            }
          }
        },
        {
          "name": "Get All Metal Details",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/metaldetail",
