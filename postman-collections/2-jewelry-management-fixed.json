              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"metaldetailId\": \"MTL-{{$randomInt}}\",\n  \"name\": \"18K White Gold\",\n  \"purity\": \"18K\",\n  \"color\": \"White\",\n  \"description\": \"Premium 18K white gold\",\n  \"pricePerGram\": 65.50,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/metaldetail",
