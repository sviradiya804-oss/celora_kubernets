{
  "info": {
    "name": "Celora Backend - Jewelry Management",
    "description": "Complete collection for jewelry CRUD operations, categories, shapes, metals, diamonds, and all jewelry-related management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://celora-backend.vercel.app",
      "type": "string"
    },
    {
      "key": "localUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "jewelryId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Jewelry CRUD",
      "item": [
        {
          "name": "Create Jewelry",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data._id) {",
                  "        pm.collectionVariables.set('jewelryId', response.data._id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jewelryId\": \"JWL-{{$randomUUID}}\",\n  \"title\": \"Elegant Diamond Engagement Ring\",\n  \"description\": \"Beautiful solitaire engagement ring with VS1 clarity diamond\",\n  \"slug\": \"elegant-diamond-engagement-ring\",\n  \"category\": \"6870abab68f9b4a37c8c856c\",\n  \"collection\": \"67123456789abcdef0123456\",\n  \"jewelryType\": \"Engagement Ring\",\n  \"type\": \"engagement\",\n  \"subType\": \"67123456789abcdef0123457\",\n  \"subTypeModel\": \"engagementsubtypelist\",\n  \"cadCode\": \"CAD-{{$randomInt}}\",\n  \"metalWeight\": {\n    \"gold14k\": 3.5,\n    \"gold18k\": 4.2,\n    \"platinum\": 5.1,\n    \"silver\": 2.8\n  },\n  \"shape\": \"6884b4355b8a2ab54b74cd0a\",\n  \"metaldetail\": \"686ab482d853bd069777c9f2\",\n  \"ringsize\": \"68123456789abcdef0123456\",\n  \"occasion\": \"6870abab68f9b4a37c8c856c\",\n  \"centerStone\": {\n    \"shape\": \"6884b4355b8a2ab54b74cd0a\",\n    \"carat\": 1.5,\n    \"color\": \"F\",\n    \"clarity\": \"VS1\",\n    \"cut\": \"Excellent\",\n    \"certification\": \"GIA\",\n    \"certificateNumber\": \"GIA123456789\"\n  },\n  \"centerStoneVariation\": [\n    {\n      \"carat\": 1.0,\n      \"shape\": \"6884b4355b8a2ab54b74cd0a\",\n      \"price\": 5000,\n      \"color\": \"G\",\n      \"clarity\": \"VS2\"\n    },\n    {\n      \"carat\": 1.5,\n      \"shape\": \"6884b4355b8a2ab54b74cd0a\",\n      \"price\": 8500,\n      \"color\": \"F\",\n      \"clarity\": \"VS1\"\n    }\n  ],\n  \"lcVariations\": [\n    {\n      \"labourCostId\": \"67123456789abcdef0123458\",\n      \"metalType\": \"Gold 14K\",\n      \"cost\": 450\n    },\n    {\n      \"labourCostId\": \"67123456789abcdef0123459\",\n      \"metalType\": \"Platinum\",\n      \"cost\": 650\n    }\n  ],\n  \"otherDiamonds\": [\n    {\n      \"position\": \"Side Stones\",\n      \"quantity\": 6,\n      \"totalCarat\": 0.18,\n      \"shape\": \"Round\",\n      \"color\": \"G\",\n      \"clarity\": \"VS\",\n      \"pricePerCarat\": 800\n    }\n  ],\n  \"pricing\": {\n    \"basePrice\": 2500,\n    \"metalPremium\": {\n      \"gold14k\": 0,\n      \"gold18k\": 200,\n      \"platinum\": 500\n    },\n    \"labourCost\": 450,\n    \"makingCharges\": 300,\n    \"otherCharges\": 100,\n    \"discount\": 0,\n    \"tax\": 250,\n    \"finalPrice\": 3600\n  },\n  \"engravingOptions\": {\n    \"available\": true,\n    \"maxCharacters\": 25,\n    \"fonts\": [\"Script\", \"Block\", \"Cursive\"],\n    \"positions\": [\"Inside Band\", \"Outside Band\"],\n    \"additionalCost\": 50\n  },\n  \"metaDetails\": {\n    \"metaTitle\": \"Elegant Diamond Engagement Ring - Celora Jewelry\",\n    \"metaDescription\": \"Stunning solitaire engagement ring with premium diamond\",\n    \"metaKeywords\": \"engagement ring, diamond ring, solitaire, wedding jewelry\"\n  },\n  \"images\": [\n    \"https://example.com/ring1.jpg\",\n    \"https://example.com/ring2.jpg\",\n    \"https://example.com/ring3.jpg\"\n  ],\n  \"status\": \"Active\",\n  \"featuredProduct\": true,\n  \"inStock\": true,\n  \"stockQuantity\": 10,\n  \"customizedJewelry\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/jewelry",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jewelry"]
            }
          }
        },
        {
          "name": "Get All Jewelry",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/jewelry?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jewelry"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Single Jewelry",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/jewelry/{{jewelryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jewelry", "{{jewelryId}}"]
            }
          }
        },
        {
          "name": "Update Jewelry",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Elegant Diamond Engagement Ring\",\n  \"description\": \"Updated description with new features\",\n  \"pricing\": {\n    \"basePrice\": 2700,\n    \"finalPrice\": 3800\n  },\n  \"status\": \"Active\",\n  \"featuredProduct\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/jewelry/{{jewelryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jewelry", "{{jewelryId}}"]
            }
          }
        },
        {
          "name": "Delete Jewelry",
