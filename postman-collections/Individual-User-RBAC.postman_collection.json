{
  "info": {
    "_postman_id": "individual-user-rbac",
    "name": "RBAC - Individual User Permissions (Compact)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Compact collection to manage role + individual permissions for a user (assign role, add individual permission, verify combined permissions)."
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "admin_token", "value": "" },
    { "key": "demo_user_id", "value": "" },
    { "key": "manager_role_id", "value": "" }
  ],
  "item": [
    {
      "name": "1 - Admin Login",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@celora.com\",\n  \"password\": \"admin123\"\n}"
        },
        "url": "{{base_url}}/api/v1/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  var r = pm.response.json();",
              "  pm.collectionVariables.set('admin_token', r.token);",
              "  console.log('Stored admin_token');",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "2 - Get Roles (store Manager id)",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{admin_token}}" } ],
        "url": "{{base_url}}/api/role-management/roles"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  var roles = pm.response.json().roles || [];",
              "  var m = roles.find(r => r.name && r.name.toUpperCase() === 'MANAGER');",
              "  if (m) pm.collectionVariables.set('manager_role_id', m._id);",
              "  console.log('manager_role_id set:', m ? m._id : 'not found');",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "3 - Search user by email (demo@yopmail.com)",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{admin_token}}" } ],
        "url": {
          "raw": "{{base_url}}/api/user-permissions/users/search?q=demo@yopmail.com",
          "query": [ { "key": "q", "value": "demo@yopmail.com" } ],
          "host": [ "{{base_url}}" ],
          "path": [ "api", "user-permissions", "users", "search" ]
        }
      },
      "event": [ { "listen": "test", "script": { "exec": [ "if (pm.response.code === 200) { var r = pm.response.json(); if (r.users && r.users.length>0) pm.collectionVariables.set('demo_user_id', r.users[0]._id); }" ] } } ]
    },
    {
      "name": "4 - Assign Manager role to demo user",
      "request": {
        "method": "POST",
        "header": [ { "key": "Authorization", "value": "Bearer {{admin_token}}" }, { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{ \"roleId\": \"{{manager_role_id}}\" }" },
        "url": "{{base_url}}/api/user-permissions/users/{{demo_user_id}}/role"
      }
    },
    {
      "name": "5 - Add individual permission: dashboard",
      "request": {
        "method": "POST",
        "header": [ { "key": "Authorization", "value": "Bearer {{admin_token}}" }, { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{ \"resource\": \"dashboard\", \"actions\": [\"read\", \"analytics\"] }" },
        "url": "{{base_url}}/api/user-permissions/users/{{demo_user_id}}/permissions/add"
      }
    },
    {
      "name": "6 - Get user effective permissions",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{admin_token}}" } ],
        "url": "{{base_url}}/api/user-permissions/users/{{demo_user_id}}"
      }
    },
    {
      "name": "7 - Update dashboard permission actions",
      "request": {
        "method": "PATCH",
        "header": [ { "key": "Authorization", "value": "Bearer {{admin_token}}" }, { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{ \"actions\": [\"read\", \"analytics\", \"admin\"] }" },
        "url": "{{base_url}}/api/user-permissions/users/{{demo_user_id}}/permissions/dashboard"
      }
    },
    {
      "name": "8 - Delete dashboard individual permission",
      "request": {
        "method": "DELETE",
        "header": [ { "key": "Authorization", "value": "Bearer {{admin_token}}" } ],
        "url": "{{base_url}}/api/user-permissions/users/{{demo_user_id}}/permissions/dashboard"
      }
    },
    {
      "name": "9 - Get available permissions reference",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{admin_token}}" } ],
        "url": "{{base_url}}/api/user-permissions/available-permissions"
      }
    }
  ]
}
