{
  "info": {
    "name": "Role Management System API",
    "description": "Individual role permission editing capabilities for RBAC system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{admin_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-authenticate if no token exists",
          "if (!pm.environment.get('admin_token')) {",
          "    pm.sendRequest({",
          "        url: pm.environment.get('base_url') + '/api/v1/auth/login',",
          "        method: 'POST',",
          "        header: {",
          "            'Content-Type': 'application/json'",
          "        },",
          "        body: {",
          "            mode: 'raw',",
          "            raw: JSON.stringify({",
          "                email: 'admin@celora.com',",
          "                password: 'admin123'",
          "            })",
          "        }",
          "    }, function (err, response) {",
          "        if (!err && response.code === 200) {",
          "            const token = response.json().token;",
          "            pm.environment.set('admin_token', token);",
          "            console.log('Auto-authenticated successfully');",
          "        }",
          "    });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has token', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('token');",
                  "    pm.environment.set('admin_token', responseJson.token);",
                  "});",
                  "",
                  "pm.test('User is admin', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.user.role.name).to.eql('Admin');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@celora.com\",\n    \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Role Listing & Details",
      "item": [
        {
          "name": "List All Roles",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has roles array', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('roles');",
                  "    pm.expect(responseJson.roles).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Store first role ID for testing', function () {",
                  "    const responseJson = pm.response.json();",
                  "    if (responseJson.roles.length > 0) {",
                  "        pm.environment.set('test_role_id', responseJson.roles[0]._id);",
                  "        pm.environment.set('test_role_name', responseJson.roles[0].name);",
                  "    }",
                  "});",
                  "",
                  "pm.test('Roles have required properties', function () {",
                  "    const responseJson = pm.response.json();",
                  "    if (responseJson.roles.length > 0) {",
                  "        const role = responseJson.roles[0];",
                  "        pm.expect(role).to.have.property('_id');",
                  "        pm.expect(role).to.have.property('name');",
                  "        pm.expect(role).to.have.property('permissions');",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/role-management/roles",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "role-management",
                "roles"
              ]
            }
          }
        },
        {
          "name": "Get Role Details",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has role details', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('role');",
                  "    pm.expect(responseJson.role).to.have.property('_id');",
                  "    pm.expect(responseJson.role).to.have.property('name');",
                  "    pm.expect(responseJson.role).to.have.property('permissions');",
                  "    pm.expect(responseJson.role).to.have.property('users');",
                  "});",
                  "",
                  "pm.test('Permissions have required structure', function () {",
                  "    const responseJson = pm.response.json();",
                  "    if (responseJson.role.permissions.length > 0) {",
                  "        const permission = responseJson.role.permissions[0];",
                  "        pm.expect(permission).to.have.property('resource');",
                  "        pm.expect(permission).to.have.property('actions');",
                  "        pm.expect(permission.actions).to.be.an('array');",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/role-management/roles/{{test_role_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "role-management",
                "roles",
                "{{test_role_id}}"
              ]
            }
          }
        },
        {
          "name": "Get Available Permissions",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has groups and resources', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('groups');",
                  "    pm.expect(responseJson).to.have.property('resources');",
                  "    pm.expect(responseJson.groups).to.be.an('array');",
                  "    pm.expect(responseJson.resources).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Groups have required structure', function () {",
                  "    const responseJson = pm.response.json();",
                  "    if (responseJson.groups.length > 0) {",
                  "        const group = responseJson.groups[0];",
                  "        pm.expect(group).to.have.property('name');",
                  "        pm.expect(group).to.have.property('resources');",
                  "        pm.expect(group.resources).to.be.an('array');",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/role-management/available-permissions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "role-management",
                "available-permissions"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Role Creation",
      "item": [
        {
          "name": "Create New Role",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has created role', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('role');",
                  "    pm.expect(responseJson.role).to.have.property('_id');",
                  "    pm.expect(responseJson.role).to.have.property('name');",
                  "    pm.expect(responseJson.role).to.have.property('permissions');",
                  "});",
                  "",
                  "pm.test('Store new role ID for testing', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.environment.set('new_role_id', responseJson.role._id);",
                  "    pm.environment.set('new_role_name', responseJson.role.name);",
                  "});",
                  "",
                  "pm.test('Role has correct permissions', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.role.permissions).to.have.lengthOf(2);",
                  "    ",
                  "    const productsPerm = responseJson.role.permissions.find(p => p.resource === 'products');",
                  "    const ordersPerm = responseJson.role.permissions.find(p => p.resource === 'orders');",
                  "    ",
                  "    pm.expect(productsPerm).to.exist;",
                  "    pm.expect(ordersPerm).to.exist;",
                  "    pm.expect(productsPerm.actions).to.include('read');",
                  "    pm.expect(ordersPerm.actions).to.include('read');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Test Manager Role\",\n    \"description\": \"A test role for demonstration of individual permission editing\",\n    \"permissions\": [\n        {\n            \"resource\": \"products\",\n            \"actions\": [\"read\"]\n        },\n        {\n            \"resource\": \"orders\",\n            \"actions\": [\"read\"]\n        }\n    ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/role-management/roles",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "role-management",
                "roles"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4. Individual Permission Management",
      "item": [
        {
          "name": "Add Permission to Role",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Permission added successfully', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('message');",
                  "    pm.expect(responseJson).to.have.property('role');",
                  "    ",
                  "    const inventoryPerm = responseJson.role.permissions.find(p => p.resource === 'inventory');",
                  "    pm.expect(inventoryPerm).to.exist;",
                  "    pm.expect(inventoryPerm.actions).to.include('read');",
                  "    pm.expect(inventoryPerm.actions).to.include('update');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"resource\": \"inventory\",\n    \"actions\": [\"read\", \"update\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/role-management/roles/{{new_role_id}}/permissions/add",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "role-management",
                "roles",
                "{{new_role_id}}",
                "permissions",
                "add"
              ]
            }
          }
        },
        {
          "name": "Update Permission Actions",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Permission actions updated successfully', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('message');",
                  "    pm.expect(responseJson).to.have.property('role');",
                  "    ",
                  "    const inventoryPerm = responseJson.role.permissions.find(p => p.resource === 'inventory');",
                  "    pm.expect(inventoryPerm).to.exist;",
                  "    pm.expect(inventoryPerm.actions).to.include('read');",
                  "    pm.expect(inventoryPerm.actions).to.include('create');",
                  "    pm.expect(inventoryPerm.actions).to.include('update');",
                  "    pm.expect(inventoryPerm.actions).to.include('delete');",
                  "    pm.expect(inventoryPerm.actions).to.have.lengthOf(4);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"actions\": [\"read\", \"create\", \"update\", \"delete\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/role-management/roles/{{new_role_id}}/permissions/inventory",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "role-management",
                "roles",
                "{{new_role_id}}",
                "permissions",
                "inventory"
              ]
            }
          }
        },
        {
          "name": "Remove Permission from Role",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Permission removed successfully', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('message');",
                  "    pm.expect(responseJson).to.have.property('role');",
                  "    ",
                  "    const ordersPerm = responseJson.role.permissions.find(p => p.resource === 'orders');",
                  "    pm.expect(ordersPerm).to.not.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/role-management/roles/{{new_role_id}}/permissions/orders",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "role-management",
                "roles",
                "{{new_role_id}}",
                "permissions",
                "orders"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "5. Bulk Permission Management",
      "item": [
        {
          "name": "Bulk Update Role Permissions",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Bulk permissions updated successfully', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('message');",
                  "    pm.expect(responseJson).to.have.property('role');",
                  "    pm.expect(responseJson.role.permissions).to.have.lengthOf(3);",
                  "    ",
                  "    const resources = responseJson.role.permissions.map(p => p.resource);",
                  "    pm.expect(resources).to.include('products');",
                  "    pm.expect(resources).to.include('customers');",
                  "    pm.expect(resources).to.include('reports');",
                  "});",
                  "",
                  "pm.test('Permission actions are correct', function () {",
                  "    const responseJson = pm.response.json();",
                  "    ",
                  "    const productsPerm = responseJson.role.permissions.find(p => p.resource === 'products');",
                  "    const customersPerm = responseJson.role.permissions.find(p => p.resource === 'customers');",
                  "    const reportsPerm = responseJson.role.permissions.find(p => p.resource === 'reports');",
                  "    ",
                  "    pm.expect(productsPerm.actions).to.include('read');",
                  "    pm.expect(productsPerm.actions).to.include('create');",
                  "    pm.expect(productsPerm.actions).to.include('update');",
                  "    ",
                  "    pm.expect(customersPerm.actions).to.include('read');",
                  "    pm.expect(customersPerm.actions).to.include('update');",
                  "    ",
                  "    pm.expect(reportsPerm.actions).to.include('read');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"permissions\": [\n        {\n            \"resource\": \"products\",\n            \"actions\": [\"read\", \"create\", \"update\"]\n        },\n        {\n            \"resource\": \"customers\",\n            \"actions\": [\"read\", \"update\"]\n        },\n        {\n            \"resource\": \"reports\",\n            \"actions\": [\"read\"]\n        }\n    ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/role-management/roles/{{new_role_id}}/permissions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "role-management",
                "roles",
                "{{new_role_id}}",
                "permissions"
              ]
            }
          }
        }
      ]
    },
