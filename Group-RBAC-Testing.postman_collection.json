                  "    body: {",
                  "        mode: 'raw',",
                  "        raw: JSON.stringify({",
                  "            role: pm.environment.get('test_role_id')",
                  "        })",
                  "    }",
                  "}, function(err, response) {",
                  "    console.log('User role updated:', response ? response.status : 'error');",
                  "});"
