    {
      "name": "2. Group Permission Management",
      "item": [
        {
          "name": "Get All Page Groups",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Groups retrieved successfully', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('groups');",
                  "    pm.expect(responseJson.groups).to.have.property('pricemanagement');",
                  "    pm.expect(responseJson.groups.pricemanagement).to.include('exchangerate');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{admin_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/permissions/groups",
              "host": ["{{base_url}}"],
              "path": ["api", "permissions", "groups"]
            }
          }
        },
        {
          "name": "Get ADMIN Role Permissions",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin role permissions retrieved', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('role');",
                  "    pm.environment.set('admin_role_id', responseJson.role._id);",
                  "});"
                ]
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Get ADMIN role ID first",
                  "pm.sendRequest({",
                  "    url: pm.environment.get('base_url') + '/api/v1/rbac/roles',",
                  "    method: 'GET',",
                  "    header: {",
                  "        'Authorization': 'Bearer ' + pm.environment.get('admin_token')",
                  "    }",
                  "}, function (err, response) {",
                  "    if (!err) {",
                  "        const roles = response.json().roles;",
                  "        const adminRole = roles.find(r => r.name === 'ADMIN');",
                  "        if (adminRole) {",
                  "            pm.environment.set('admin_role_id', adminRole._id);",
                  "        }",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{admin_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/permissions/roles/{{admin_role_id}}/permissions",
              "host": ["{{base_url}}"],
              "path": ["api", "permissions", "roles", "{{admin_role_id}}", "permissions"]
            }
          }
        },
        {
          "name": "Create Test Role with Group Permissions",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Test role created successfully', function () {",
                  "    pm.response.to.have.status(201);",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('role');",
                  "    pm.environment.set('test_role_id', responseJson.role._id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{admin_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"TEST_MANAGER\",\n  \"description\": \"Test role with group permissions\",\n  \"permissions\": [\n    {\n      \"resource\": \"pricemanagement\",\n      \"actions\": [\"read\", \"update\"],\n      \"group\": null\n    },\n    {\n      \"resource\": \"jewelry\",\n      \"actions\": [\"create\", \"read\", \"update\"],\n      \"group\": null\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/rbac/roles",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "rbac", "roles"]
            }
          }
        },
        {
          "name": "Update Role with Group Permissions",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Role permissions updated successfully', function () {",
