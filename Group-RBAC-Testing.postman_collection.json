            },
            "url": {
              "raw": "{{base_url}}/api/permissions/roles/{{test_role_id}}/permissions",
              "host": ["{{base_url}}"],
              "path": ["api", "permissions", "roles", "{{test_role_id}}", "permissions"]
            }
          }
        },
