	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{AUTH_TOKEN}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Ensure we have a session ID",
					"if (!pm.collectionVariables.get('TEST_SESSION_ID')) {",
					"    const sessionId = 'session-' + Date.now() + '-' + Math.random().toString(36).substr(2, 9);",
					"    pm.collectionVariables.set('TEST_SESSION_ID', sessionId);",
					"}",
					"",
					"// Add timing for performance monitoring",
					"pm.globals.set('requestStartTime', Date.now());"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Global security checks",
					"pm.test('Response time is acceptable', function () {",
					"    const startTime = pm.globals.get('requestStartTime');",
					"    const responseTime = Date.now() - startTime;",
					"    pm.expect(responseTime).to.be.below(5000); // 5 seconds max",
					"});",
					"",
					"pm.test('No script tags in response', function () {",
					"    const responseText = pm.response.text();",
					"    pm.expect(responseText).to.not.include('<script>');",
					"    pm.expect(responseText).to.not.include('javascript:');",
					"});",
					"",
					"pm.test('No sensitive data exposed', function () {",
					"    const responseText = pm.response.text().toLowerCase();",
					"    pm.expect(responseText).to.not.include('password');",
					"    pm.expect(responseText).to.not.include('secret');",
					"    pm.expect(responseText).to.not.include('private_key');",
					"    pm.expect(responseText).to.not.include('api_key');",
					"});",
					"",
					"// Log security test results",
					"if (pm.request.name.includes('🔴')) {",
					"    if (pm.response.code >= 400) {",
					"        console.log('✅ Security test passed - Request properly rejected');",
					"    } else {",
					"        console.log('⚠️ Security test warning - Request was accepted');",
					"    }",
					"}",
					"",
					"// Response structure validation",
					"if (pm.response.code < 400) {",
					"    pm.test('Response has proper structure', function () {",
					"        const response = pm.response.json();",
					"        pm.expect(response).to.be.an('object');",
					"    });",
					"}"
				]
			}
		}
	],
